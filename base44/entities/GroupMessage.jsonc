{
  "name": "GroupMessage",
  "type": "object",
  "properties": {
    "group_id": {
      "type": "string",
      "description": "ID of the group this message belongs to"
    },
    "author_email": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "message": {
      "type": "string",
      "maxLength": 500
    }
  },
  "required": [
    "group_id",
    "author_email",
    "message"
  ]
}