{
  "name": "PrayerRequest",
  "type": "object",
  "properties": {
    "author_name": {
      "type": "string",
      "description": "Display name of the person requesting prayer"
    },
    "author_email": {
      "type": "string",
      "description": "Email of the person requesting prayer"
    },
    "title": {
      "type": "string",
      "description": "Short title of the prayer request"
    },
    "content": {
      "type": "string",
      "description": "Full details of the prayer request"
    },
    "praying_users": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of emails of users who have clicked Praying"
    },
    "bookmarked_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of emails of users who bookmarked this prayer request"
    },
    "private_notes": {
      "type": "string",
      "description": "Private notes by the owner documenting how God answered this prayer over time"
    },
    "is_anonymous": {
      "type": "boolean",
      "default": false
    },
    "category": {
      "type": "string",
      "enum": [
        "health",
        "family",
        "finances",
        "guidance",
        "gratitude",
        "relationships",
        "other"
      ],
      "default": "other"
    }
  },
  "required": [
    "content",
    "author_email"
  ],
  "rls": {
    "delete": {
      "data.author_email": "{{user.email}}"
    },
    "update": {
      "data.author_email": "{{user.email}}"
    },
    "write": {
      "data.author_email": "{{user.email}}"
    }
  }
}